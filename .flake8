[flake8]
max-line-length = 200
extend-ignore =
    E203
    W503
    E501
exclude =
    .git,
    __pycache__,
    .venv,
    env,
    venv,
    build,
    dist,
    *.egg-info,
    assets/,
    media/,
    simulation/ardupilot_stl/,
per-file-ignores =
    __init__.py:F401
    tests/*:E501
    scripts/*:E501
    **/manim/*:E501
max-complexity = 10
